# Provider secrets — copy thành .env.providers (KHÔNG commit .env.providers)
# Dùng cho docker-compose.providers.yml

# ── Backend HDOS endpoints ───────────────────────────────────────────────────
# Gateway HTTPS → token endpoint
HDOS_TOKEN_ENDPOINT=https://192.168.100.60:8443/api/v1/providers/token

# gRPC provider-bridge (port 5400 expose trực tiếp, không qua gateway)
HDOS_BRIDGE_GRPC_URL=http://192.168.100.60:5400

# ── Excel Provider ───────────────────────────────────────────────────────────
EXCEL_PROVIDER_IMAGE=foxai/excel-provider:latest
EXCEL_PROVIDER_SECRET=change-me-strong-secret

# ── Log level ────────────────────────────────────────────────────────────────
LOG_LEVEL=Information

# ── Thêm secrets provider khác tại đây ──────────────────────────────────────
# MY_PROVIDER_SECRET=change-me
